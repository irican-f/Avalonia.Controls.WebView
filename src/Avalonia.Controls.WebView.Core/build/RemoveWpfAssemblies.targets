<Project>
  <Target Name="RemoveWinFormsWpfAssemblies" BeforeTargets="ResolveAssemblyReferences">
    <ItemGroup>
      <ReferencesToRemove
        Include="@(Reference)"
        Condition="'%(Filename)' == 'Microsoft.Web.WebView2.Wpf'"  />
      <ReferencesToRemove
        Include="@(Reference)"
        Condition="'%(Filename)' == 'Microsoft.Web.WebView2.WinForms'"  />
    </ItemGroup>
    <ItemGroup>
      <Reference Remove="@(ReferencesToRemove)" />
    </ItemGroup>
  </Target>
  <Target Name="RemoveWinFormsWpfFromPublish" AfterTargets="ComputeResolvedFilesToPublishList">
    <ItemGroup>
      <ResolvedFileToPublishToRemove
        Include="@(ResolvedFileToPublish)"
        Condition="'%(Filename)' == 'Microsoft.Web.WebView2.Wpf'"  />
      <ResolvedFileToPublishToRemove
        Include="@(ResolvedFileToPublish)"
        Condition="'%(Filename)' == 'Microsoft.Web.WebView2.WinForms'"  />
      <!--      <ResolvedFileToPublishToRemove-->
      <!--        Include="@(ResolvedFileToPublish)"-->
      <!--        Condition="'%(Filename)' == 'WebView2Loader'"  />-->
    </ItemGroup>
    <ItemGroup>
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublishToRemove)" />
    </ItemGroup>
  </Target>
</Project>
