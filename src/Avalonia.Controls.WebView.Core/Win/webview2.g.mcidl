struct tagRECT
{
  int left;
  int top;
  int right;
  int bottom;
}

[uuid(2FDE08A8-1E9A-4766-8C05-95A9CEB9D1C5)]
interface ICoreWebView2EnvironmentOptions : IUnknown
{
	HRESULT get_AdditionalBrowserArguments(LPWSTR* value);
	HRESULT put_AdditionalBrowserArguments(LPCWSTR value);
	HRESULT get_Language(LPWSTR* value);
	HRESULT put_Language(LPCWSTR value);
	HRESULT get_TargetCompatibleBrowserVersion(LPWSTR* value);
	HRESULT put_TargetCompatibleBrowserVersion(LPCWSTR value);
	HRESULT get_AllowSingleSignOnUsingOSPrimaryAccount(BOOL* allow);
	HRESULT put_AllowSingleSignOnUsingOSPrimaryAccount(BOOL allow);
}

[uuid(4E8A3389-C9D8-4BD2-B6B5-124FEE6CC14D)]
interface ICoreWebView2CreateCoreWebView2EnvironmentCompletedHandler : IUnknown
{
    HRESULT Invoke(HRESULT errorCode, ICoreWebView2Environment* result);
}

[uuid(B96D755E-0319-4E92-A296-23436F46A1FC)]
interface ICoreWebView2Environment : IUnknown
{
    int CreateCoreWebView2Controller(HWND parentWindow, ICoreWebView2CreateCoreWebView2ControllerCompletedHandler* handler);
    HRESULT CreateWebResourceResponse(void* content, int statusCode, LPCWSTR reasonPhrase, LPCWSTR headers, void** response);
    HRESULT get_BrowserVersionString(LPWSTR * versionInfo);
}

[uuid(6C4819F3-C9B7-4260-8127-C9F5BDE7F68C)]
interface ICoreWebView2CreateCoreWebView2ControllerCompletedHandler : IUnknown
{
    int Invoke(HRESULT errorCode, ICoreWebView2Controller * result);
}

[uuid(4D00C0D1-9434-4EB6-8078-8697A560334F)]
interface ICoreWebView2Controller : IUnknown
{
    HRESULT get_IsVisible(BOOL* isVisible);
    HRESULT put_IsVisible(BOOL isVisible);
    HRESULT get_Bounds(tagRECT* bounds);
    HRESULT put_Bounds(tagRECT bounds);
    HRESULT get_ZoomFactor(DOUBLE* zoomFactor);
    HRESULT put_ZoomFactor(DOUBLE zoomFactor);
    HRESULT add_ZoomFactorChanged(IWebView2ZoomFactorChangedEventHandler* eventHandler, EventRegistrationToken* token);
    HRESULT remove_ZoomFactorChanged(EventRegistrationToken token);
    HRESULT SetBoundsAndZoomFactor(tagRECT bounds, DOUBLE zoomFactor);
    HRESULT MoveFocus(int reason);
    HRESULT add_MoveFocusRequested(IWebView2MoveFocusRequestedEventHandler* eventHandler, EventRegistrationToken* token);
    HRESULT remove_MoveFocusRequested(EventRegistrationToken token);
    HRESULT add_GotFocus(IWebView2FocusChangedEventHandler* eventHandler, EventRegistrationToken* token);
    HRESULT remove_GotFocus(EventRegistrationToken token);
    HRESULT add_LostFocus(IWebView2FocusChangedEventHandler* eventHandler, EventRegistrationToken* token);
    HRESULT remove_LostFocus(EventRegistrationToken token);
    HRESULT add_AcceleratorKeyPressed(void* eventHandler, EventRegistrationToken* token);
    HRESULT remove_AcceleratorKeyPressed(EventRegistrationToken token);
    HRESULT get_ParentWindow(HWND* parentWindow);
    HRESULT put_ParentWindow(HWND parentWindow);
    HRESULT NotifyParentWindowPositionChanged();
    HRESULT Close();
    HRESULT get_CoreWebView2(void** coreWebView);
}


