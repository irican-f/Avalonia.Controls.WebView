[uuid(76711B9E-8D56-4806-8485-35250BB2384F)]
interface IWebView2WebView : IUnknown
{
    HRESULT get_Settings(void **settings);   
    HRESULT get_Source(LPWSTR *uri);
    HRESULT Navigate(LPCWSTR uri);
    HRESULT MoveFocus(int reason);
    HRESULT NavigateToString(LPCWSTR htmlContent);
    HRESULT add_NavigationStarting(IWebView2NavigationStartingEventHandler *eventHandler, EventRegistrationToken *token);    
    HRESULT remove_NavigationStarting(EventRegistrationToken token);
    HRESULT add_DocumentStateChanged(IWebView2DocumentStateChangedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_DocumentStateChanged(EventRegistrationToken token);
    HRESULT add_NavigationCompleted(IWebView2NavigationCompletedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_NavigationCompleted(EventRegistrationToken token);
    HRESULT add_FrameNavigationStarting(IWebView2NavigationStartingEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_FrameNavigationStarting(EventRegistrationToken token);
    HRESULT add_MoveFocusRequested(IWebView2MoveFocusRequestedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_MoveFocusRequested(EventRegistrationToken token);
    HRESULT add_GotFocus(IWebView2FocusChangedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_GotFocus(EventRegistrationToken token);
    HRESULT add_LostFocus(IWebView2FocusChangedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_LostFocus(EventRegistrationToken token);    
    HRESULT add_WebResourceRequested(LPCWSTR* urlFilter, void* resourceContextFilter, SIZE_T filterLength, void *eventHandler, EventRegistrationToken *token);
    HRESULT remove_WebResourceRequested(EventRegistrationToken token);
    HRESULT add_ScriptDialogOpening(void *eventHandler, EventRegistrationToken *token);
    HRESULT remove_ScriptDialogOpening(EventRegistrationToken token);
    HRESULT add_ZoomFactorChanged(IWebView2ZoomFactorChangedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_ZoomFactorChanged(EventRegistrationToken token);
    HRESULT add_PermissionRequested(IWebView2PermissionRequestedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_PermissionRequested(EventRegistrationToken token);
    HRESULT add_ProcessFailed(IWebView2ProcessFailedEventHandler *eventHandler, EventRegistrationToken *token);
    HRESULT remove_ProcessFailed(EventRegistrationToken token);
    HRESULT AddScriptToExecuteOnDocumentCreated(LPCWSTR javaScript, IWebView2AddScriptToExecuteOnDocumentCreatedCompletedHandler *handler);
    HRESULT RemoveScriptToExecuteOnDocumentCreated(LPCWSTR id);
    HRESULT ExecuteScript(LPCWSTR javaScript, IWebView2ExecuteScriptCompletedHandler *handler);
    HRESULT CapturePreview(int imageFormat, void *imageStream, void *handler);
    HRESULT Reload();
    HRESULT get_Bounds(tagRECT *bounds);
    HRESULT put_Bounds(tagRECT bounds);
    HRESULT get_ZoomFactor(double *zoomFactor);
    HRESULT put_ZoomFactor(double zoomFactor);
    HRESULT get_IsVisible(BOOL *isVisible);
    HRESULT put_IsVisible(BOOL isVisible);
    HRESULT PostWebMessageAsJson(LPCWSTR webMessageAsJson);
    HRESULT PostWebMessageAsString(LPCWSTR webMessageAsString);
    HRESULT add_WebMessageReceived(IWebView2WebMessageReceivedEventHandler *handler, EventRegistrationToken *token);
    HRESULT remove_WebMessageReceived(EventRegistrationToken token);
    HRESULT Close();
    HRESULT CallDevToolsProtocolMethod(LPCWSTR methodName, LPCWSTR parametersAsJson, void *handler);
    HRESULT add_DevToolsProtocolEventReceived(LPCWSTR eventName, void*handler, EventRegistrationToken *token);
    HRESULT remove_DevToolsProtocolEventReceived(LPCWSTR eventName, EventRegistrationToken token);
    HRESULT get_BrowserProcessId(UINT32 *value);
    HRESULT get_CanGoBack(BOOL *canGoBack);
    HRESULT get_CanGoForward(BOOL *canGoForward);
    int GoBack();
    int GoForward();
};
