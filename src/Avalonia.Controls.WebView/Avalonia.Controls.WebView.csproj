<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>
      netstandard2.0;
      net8.0;net8.0-android
    </TargetFrameworks>
    <Description>Avalonia WebView component enables embedding web content in Avalonia applications for use cases like documentation, dashboards, and interactive content.</Description>
    <DefineConstants>$(DefineConstants);AVALONIA</DefineConstants>
    <RootNamespace>Avalonia.Controls</RootNamespace>
    <CopyLocalLockFileAssemblies Condition="'$(ILMergeBuild)' == 'true'">true</CopyLocalLockFileAssemblies>
    <AndroidGenerateResourceDesigner>false</AndroidGenerateResourceDesigner>
    <AvnLicensingEmitBuildTime>true</AvnLicensingEmitBuildTime>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AvaloniaUI.Licensing" Version="2.0.0-cibuild000081" />
    <ProjectReference Include="..\Avalonia.Controls.WebView.Core\Avalonia.Controls.WebView.Core.csproj" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="build\**\*" PackagePath="build;buildTransitive" />
  </ItemGroup>

  <Import Project="../Avalonia.Controls.WebView.Core/IncludeBuildItems.props" />
  <Import Project="$(RepositoryTargetsRoot)/PackEnable.targets" />
  <Import Project="$(RepositoryTargetsRoot)/SignEnable.targets" />
</Project>

