<Project>
  <PropertyGroup>
    <BuildTime>$([System.DateTime]::Now.ToString('yyyy-MM-dd'))</BuildTime>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>BuildTime</_Parameter1>
      <_Parameter2>$(BuildTime)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>
</Project>
