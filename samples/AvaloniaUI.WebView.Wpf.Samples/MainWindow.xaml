<Window x:Class="AvaloniaUI.WebView.Wpf.Samples.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wpf="clr-namespace:AvaloniaUI.WebView;assembly=AvaloniaUI.WebView.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        KeyDown="MainWindow_OnKeyDown">
  <TabControl x:Name="TabControl">
    <TabItem Header="XPF">
      <Grid x:Name="GridContainer">
        <Grid.RowDefinitions>
          <RowDefinition Height="3*" />
          <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <wpf:NativeWebView x:Name="WebView"
                           Source="https://avaloniaui.net/"
                           NavigationCompleted="NativeWebView_OnNavigationCompleted"
                           NavigationStarted="NativeWebView_OnNavigationStarted"
                           WebMessageReceived="NativeWebView_OnWebMessageReceived"
                           KeyDown="WebView_OnKeyDown"/>
        <TextBox IsReadOnly="True" Grid.Row="1" x:Name="LogList" />
      </Grid>
    </TabItem>
  </TabControl>
</Window>
