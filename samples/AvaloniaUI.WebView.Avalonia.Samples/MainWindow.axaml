<Window x:Class="AvaloniaUI.WebView.Avalonia.Samples.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:webview="using:AvaloniaUI.WebView"
        Title="AvaloniaUI.WebView.Avalonia.Samples"
        d:DesignHeight="450"
        d:DesignWidth="800"
        mc:Ignorable="d">
    <TabControl>
        <TabItem Header="AvaloniaUI">
            <Grid RowDefinitions="3*, *">
                <webview:NativeWebView Source="https://avaloniaui.net/"
                                       NavigationCompleted="NativeWebView_OnNavigationCompleted"
                                       NavigationStarted="NativeWebView_OnNavigationStarted"
                                       WebMessageReceived="NativeWebView_OnWebMessageReceived"
                                       KeyDown="InputElement_OnKeyDown"/>
                <TextBox IsReadOnly="True" Grid.Row="1" x:Name="LogList" />
            </Grid>
        </TabItem>
    </TabControl>
</Window>
