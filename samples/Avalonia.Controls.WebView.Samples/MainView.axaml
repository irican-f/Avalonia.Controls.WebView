<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Avalonia.Controls.WebView.Samples.MainView"
             KeyDown="View_OnKeyDown"
             KeyUp="View_OnKeyUp">
    <TabControl x:Name="TabControl">
        <TabItem Header="AvaloniaUI">
            <Grid x:Name="GridContainer" RowDefinitions="Auto, 3*, *">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding #WebView.AdapterInfo}" />
                    <TextBlock Text="{Binding #WebView.Source}" />
                </DockPanel>
                <NativeWebView Grid.Row="1" x:Name="WebView"
                               Source="https://google.com/"
                               EnvironmentRequested="NativeWebView_OnEnvironmentRequested"
                               NavigationCompleted="NativeWebView_OnNavigationCompleted"
                               NavigationStarted="NativeWebView_OnNavigationStarted"
                               WebMessageReceived="NativeWebView_OnWebMessageReceived"
                               WebResourceRequested="NativeWebView_OnWebResourceRequested"
                               NewWindowRequested="NativeWebView_OnNewWindowRequested"
                               AdapterCreated="NativeWebView_OnAdapterCreated"
                               AdapterDestroyed="NativeWebView_OnAdapterDestroyed"
                               KeyDown="InputElement_OnKeyDown"
                               KeyUp="InputElement_OnKeyUp" />
                <TextBox IsReadOnly="True" Grid.Row="2" x:Name="LogList" />
            </Grid>
        </TabItem>
        <TabItem Header="Input types">
            <NativeWebView Source="https://www.w3schools.com/tags/att_input_type.asp"
                           NewWindowRequested="NativeWebView_OnNewWindowRequested" />
        </TabItem>
        <TabItem Header="Headers">
            <NativeWebView Source="https://httpbin.io/headers"
                           WebResourceRequested="Headers_OnWebResourceRequested" />
        </TabItem>
        <TabItem Header="GetUserMedia">
            <NativeWebView Source="https://webrtc.github.io/samples/"
                           NewWindowRequested="NativeWebView_OnNewWindowRequested" />
        </TabItem>
        <TabItem Header="Transparent">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Spacing="10"
                            Margin="10">
                    <Button Content="Transparent" Click="Make_Transparent_Clicked" />
                    <Button Content="Solid" Click="Make_Solid_Background_Clicked" />
                    <Button Content="Default" Click="Make_Default_Background_Clicked" />
                    <Button Content="Gradient" Click="Make_Gradient_Background_Clicked" />
                </StackPanel>
                <Border Background="Yellow">
                    <NativeWebView x:Name="TransparentWebView"
                                   Loaded="TransparentWebView_OnLoaded" />
                </Border>
            </DockPanel>
        </TabItem>
        <TabItem Header="Expander + Grid">
            <Expander Header="Surprise">
                <Grid RowDefinitions="Auto, *" ColumnDefinitions="*, Auto, Auto">
                    <TextBox x:Name="GridWebViewSource"
                             Text="https://avaloniaui.net"
                             Grid.Row="0" Grid.Column="0" />
                    <Button x:Name="GridWebViewButton"
                            Content="GO"
                            Click="GridWebViewButton_OnClick"
                            Grid.Row="0" Grid.Column="1" />
                    <Button Content="Dialog"
                            Click="GridWebViewDialogButton_OnClick"
                            Grid.Row="0" Grid.Column="2" />
                    <Panel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Another panel" />
                    </Panel>
                    <NativeWebView x:Name="GridWebView"
                                   Source="https://avaloniaui.net"
                                   Grid.Row="1" Grid.Column="0"/>
                </Grid>
            </Expander>
        </TabItem>
        <TabItem Header="ScrollViewer">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <StackPanel>
                    <TextBlock Text="Hello" />
                    <NativeWebView MinHeight="500"
                                   Source="https://avaloniaui.net" />
                    <TextBlock Text="There" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Pdf Page">
            <NativeWebView Source="https://sample-files.com/downloads/documents/pdf/sample-report.pdf" />
        </TabItem>
        <TabItem Header="WebAuthenticationBroker">
            <StackPanel>
                <TextBox x:Name="RequestUri"
                         UseFloatingWatermark="True"
                         Watermark="Request Uri" />
                <TextBox x:Name="RedirectUri"
                         UseFloatingWatermark="True"
                         Watermark="Redirect Uri" />
                <Button Content="Go" Click="WebAuthenticationBrokerButton_OnClick" />
                <TextBox x:Name="CallbackUri"
                         AcceptsReturn="True"
                         UseFloatingWatermark="True"
                         Watermark="Callback Uri" />
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
